{
  "version": 1,
  "agents": {
    "*": {
      "allowlist": [
        {"pattern": "mcporter"},
        {"pattern": "mcporter call odoo.*"},
        {"pattern": "python3 *send_pdf*"},
        {"pattern": "rm -f /tmp/*"},
        {"pattern": "base64 *"},
        {"pattern": "curl *api.telegram.org*"},
        {"pattern": "jq *"},
        {"pattern": "cat /tmp/*"}
      ]
    }
  }
}
