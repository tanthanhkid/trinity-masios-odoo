# /etc/odoo-mcp/credentials — Odoo MCP Server credentials
# Install: sudo mkdir -p /etc/odoo-mcp && sudo cp credentials.example /etc/odoo-mcp/credentials && sudo chmod 600 /etc/odoo-mcp/credentials
ODOO_URL=http://127.0.0.1:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=CHANGE_ME

# API token for HTTP endpoint authentication (required for remote access)
# Generate with: python3 server.py --generate-token
MCP_API_TOKEN=
