        <!-- PostgreSQL -->
        <mxCell id="pg" value="&lt;b&gt;PostgreSQL 16&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;DB: odoo&lt;br&gt;User: odoo (md5)&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;size=12;" vertex="1" parent="1">
