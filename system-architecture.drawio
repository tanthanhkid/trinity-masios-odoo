<mxfile>
  <diagram name="Odoo MCP + OpenClaw Architecture" id="arch">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Trinity Masios Odoo — System Architecture&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=20;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- ============ OPENCLAW ZONE ============ -->
        <mxCell id="oc_zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#43A047;dashed=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="440" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="oc_label" value="&lt;b&gt;🦞 OpenClaw (Any Machine)&lt;/b&gt;" style="text;html=1;align=left;fontSize=14;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="60" y="95" width="250" height="30" as="geometry"/>
        </mxCell>

        <!-- OpenClaw Agents -->
        <mxCell id="agent_ben" value="&lt;b&gt;BEN&lt;/b&gt;&lt;br&gt;Video Render" style="shape=person;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="80" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="agent_bob" value="&lt;b&gt;BOB&lt;/b&gt;&lt;br&gt;Manager" style="shape=person;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="160" y="140" width="80" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="agent_bill" value="&lt;b&gt;BILL&lt;/b&gt;&lt;br&gt;Programmer" style="shape=person;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="260" y="140" width="80" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="agent_new" value="&lt;b&gt;New Agent&lt;/b&gt;&lt;br&gt;(Any)" style="shape=person;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeDasharray=5;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="360" y="140" width="80" height="80" as="geometry"/>
        </mxCell>

        <!-- Skill -->
        <mxCell id="skill" value="&lt;b&gt;odoo-crm Skill&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;SKILL.md — teaches agents&lt;br&gt;models, fields, domain syntax,&lt;br&gt;workflows, tool usage&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;size=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="250" width="190" height="80" as="geometry"/>
        </mxCell>

        <!-- mcporter -->
        <mxCell id="mcporter" value="&lt;b&gt;mcporter CLI&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;~/.mcporter/mcporter.json&lt;br&gt;mcporter call odoo.&amp;lt;tool&amp;gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="260" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Setup box -->
        <mxCell id="setup_box" value="&lt;b&gt;Setup (2 commands):&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;1. mcporter config add odoo http://...8200/mcp&lt;br&gt;2. cp skill → ~/.openclaw/skills/odoo-crm&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=10;size=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="360" width="400" height="60" as="geometry"/>
        </mxCell>

        <!-- Arrows from agents to skill/mcporter -->
        <mxCell id="a2s1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#388E3C;" edge="1" source="agent_bill" target="mcporter" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2s2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#388E3C;dashed=1;" edge="1" source="agent_bob" target="mcporter" parent="1">
