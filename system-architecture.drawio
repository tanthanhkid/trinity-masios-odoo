        <mxCell id="cc_mcp" value="&lt;b&gt;.mcp.json&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Auto-loads MCP server&lt;br&gt;uv run --with mcp python3 server.py&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="535" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="cc_memory" value="&lt;b&gt;Memory + SQLite&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;MEMORY.md, hooks,&lt;br&gt;smart-memory.db&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;fontSize=10;size=10;" vertex="1" parent="1">
