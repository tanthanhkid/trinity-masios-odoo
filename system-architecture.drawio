        </mxCell>

        <!-- XML-RPC arrow -->
        <mxCell id="xmlrpc" value="&lt;b&gt;XML-RPC&lt;/b&gt;&lt;br&gt;/xmlrpc/2/object" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=3;fontSize=10;" edge="1" source="mcp_server" target="odoo" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Odoo -->
        <mxCell id="odoo" value="&lt;b&gt;Odoo 18.0 Community&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;HTTP :8069 / Longpoll :8072&lt;br&gt;3 workers, systemd&lt;br&gt;/opt/odoo/odoo-server/&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF8A65;strokeColor=#BF360C;fontSize=12;fontColor=#FFFFFF;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="630" y="300" width="200" height="80" as="geometry"/>
