        <!-- ============ NETWORK ============ -->
        <mxCell id="net_arrow" value="&lt;b&gt;HTTP&lt;/b&gt;&lt;br&gt;port 8200" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565C0;strokeWidth=3;fontSize=11;" edge="1" source="mcporter" target="mcp_server" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="540" y="290"/>
              <mxPoint x="540" y="190"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============ CLAUDE CODE ZONE ============ -->
        <mxCell id="cc_zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;dashed=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="440" height="150" as="geometry"/>
