        </mxCell>
        <mxCell id="cc_to_mcp" value="&lt;b&gt;stdio&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565C0;strokeWidth=2;fontSize=10;" edge="1" source="cc_mcp" target="mcp_server" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="160" y="470"/>
              <mxPoint x="540" y="470"/>
              <mxPoint x="540" y="240"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============ SERVER ZONE ============ -->
        <mxCell id="srv_zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;dashed=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="590" y="90" width="530" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="srv_label" value="&lt;b&gt;🖥️ Ubuntu Server (103.72.97.51)&lt;/b&gt;" style="text;html=1;align=left;fontSize=14;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="610" y="95" width="350" height="30" as="geometry"/>
        </mxCell>

        <!-- MCP Server -->
        <mxCell id="mcp_server" value="&lt;b&gt;Odoo MCP Server&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;server.py (FastMCP)&lt;br&gt;HTTP :8200 / stdio&lt;br&gt;systemd: odoo-mcp.service&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=12;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="630" y="140" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- 13 Tools -->
        <mxCell id="tools" value="&lt;b&gt;13 MCP Tools&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;• odoo_list_models&lt;br&gt;• odoo_model_fields&lt;br&gt;• odoo_model_access&lt;br&gt;• odoo_model_views&lt;br&gt;• odoo_crm_stages&lt;br&gt;• odoo_crm_lead_summary&lt;br&gt;• odoo_search_read&lt;br&gt;• odoo_count&lt;br&gt;• odoo_create / write / delete&lt;br&gt;• odoo_execute&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;size=14;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="870" y="130" width="220" height="180" as="geometry"/>
