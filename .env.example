# Odoo MCP Server Credentials
# Copy this to .env.local and fill in real values
# .env.local is gitignored — never commit credentials
ODOO_URL=http://your-odoo-server:8069
ODOO_DB=your_database_name
ODOO_USERNAME=your_username
ODOO_PASSWORD=your_password

# API token for HTTP endpoint authentication (optional for local stdio mode)
# Generate with: uv run --with mcp python3 mcp/odoo-server/server.py --generate-token
MCP_API_TOKEN=
