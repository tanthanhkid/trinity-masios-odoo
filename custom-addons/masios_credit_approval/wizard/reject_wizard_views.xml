<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="credit_approval_reject_wizard_form" model="ir.ui.view">
        <field name="name">credit.approval.reject.wizard.form</field>
        <field name="model">credit.approval.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Từ chối phê duyệt">
                <group>
                    <field name="approval_id" invisible="1"/>
                    <field name="reason" placeholder="Nhập lý do từ chối..."/>
                </group>
                <footer>
                    <button name="action_reject" type="object" string="Từ chối" class="btn-danger"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
