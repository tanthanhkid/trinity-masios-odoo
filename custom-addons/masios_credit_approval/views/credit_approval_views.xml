<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="credit_approval_request_list" model="ir.ui.view">
        <field name="name">credit.approval.request.list</field>
        <field name="model">credit.approval.request</field>
        <field name="arch" type="xml">
            <list decoration-warning="state == 'pending'" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="salesperson_id"/>
                <field name="amount_total" widget="monetary"/>
                <field name="outstanding_debt" widget="monetary"/>
                <field name="new_total_debt" widget="monetary"/>
                <field name="approval_threshold" widget="monetary"/>
                <field name="state" widget="badge"
                    decoration-warning="state == 'pending'"
                    decoration-success="state == 'approved'"
                    decoration-danger="state == 'rejected'"/>
                <field name="approved_by"/>
                <field name="approved_via"/>
                <field name="approved_date"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="credit_approval_request_form" model="ir.ui.view">
        <field name="name">credit.approval.request.form</field>
        <field name="model">credit.approval.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" type="object" string="✅ Duyệt"
                        class="btn-primary"
                        invisible="state != 'pending'"
                        groups="sales_team.group_sale_manager"/>
                    <button name="action_reject_wizard" type="object" string="❌ Từ chối"
                        class="btn-danger"
                        invisible="state != 'pending'"
                        groups="sales_team.group_sale_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Đơn hàng">
                            <field name="sale_order_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="salesperson_id" readonly="1"/>
                            <field name="amount_total" widget="monetary" readonly="1"/>
                        </group>
                        <group string="Công nợ">
                            <field name="outstanding_debt" widget="monetary" readonly="1"/>
                            <field name="new_total_debt" widget="monetary" readonly="1"/>
                            <field name="approval_threshold" widget="monetary" readonly="1"/>
                        </group>
                    </group>
                    <group string="Kết quả phê duyệt" invisible="state == 'pending'">
                        <group>
                            <field name="approved_by" readonly="1"/>
                            <field name="approved_via" readonly="1"/>
                            <field name="approved_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="reject_reason" readonly="1"
                                invisible="state != 'rejected'"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="credit_approval_request_search" model="ir.ui.view">
        <field name="name">credit.approval.request.search</field>
        <field name="model">credit.approval.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="salesperson_id"/>
                <filter name="pending" string="Chờ duyệt" domain="[('state', '=', 'pending')]"/>
                <filter name="approved" string="Đã duyệt" domain="[('state', '=', 'approved')]"/>
                <filter name="rejected" string="Từ chối" domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter name="today" string="Hôm nay" domain="[('create_date', '>=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                <filter name="this_month" string="Tháng này" domain="[('create_date', '>=', (context_today() - datetime.timedelta(days=context_today().day - 1)).strftime('%%Y-%%m-%%d'))]"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="group_state" string="Trạng thái" context="{'group_by': 'state'}"/>
                    <filter name="group_partner" string="Khách hàng" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_salesperson" string="Nhân viên" context="{'group_by': 'salesperson_id'}"/>
                    <filter name="group_month" string="Tháng" context="{'group_by': 'create_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_credit_approval_request" model="ir.actions.act_window">
        <field name="name">Phê duyệt công nợ</field>
        <field name="res_model">credit.approval.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="credit_approval_request_search"/>
        <field name="context">{'search_default_pending': 1}</field>
    </record>

    <!-- Menu - under Sales -->
    <menuitem id="menu_credit_approval_root"
        name="Phê duyệt công nợ"
        parent="sale.sale_menu_root"
        sequence="15"
        action="action_credit_approval_request"
        groups="sales_team.group_sale_manager"/>

</odoo>
